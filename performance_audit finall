### 3. Spline 3D iframe Blocking the Entire Hero Section

**File:** [`hero.tsx`](file:///f:/PROJECTS/wayfindsolutions/src/components/home/hero.tsx#L16-L26)

```tsx
<iframe 
  src="https://my.spline.design/crystalball-de222de54d6fc4752fa850b54fb654de/" 
  width="100%" 
  height="100%"
  loading="lazy"   // ← does NOT delay viewport iframes
/>
```

**What's happening:** A full WebGL 3D scene is loaded as the hero background. This:
- Downloads 2–5 MB from Spline's CDN (separate domain, new DNS + TLS handshake)
- Spins up a WebGL context (GPU allocation)
- `loading="lazy"` does **not** work on iframes that are already in the viewport — it loads immediately
- Blocks LCP (Largest Contentful Paint) until the iframe loads

**Impact:** 3–8 second hero load time. This is the single biggest user-facing slowdown.

**Fix:** Defer loading until after the page is interactive:

```tsx
"use client";
import { useState, useEffect } from "react";

export function Hero({ onConsultantClick }: HeroProps) {
  const [showSpline, setShowSpline] = useState(false);
  
  useEffect(() => {
    // Load Spline 2 seconds after page load — hero content is already visible
    const t = setTimeout(() => setShowSpline(true), 2000);
    return () => clearTimeout(t);
  }, []);

  return (
    <section ...>
      <div className="pointer-events-none absolute ...">
        {/* Show a gradient while Spline loads */}
        {!showSpline && (
          <div className="w-full h-full bg-gradient-to-br from-indigo-50 to-purple-50" />
        )}
        {showSpline && (
          <iframe src="https://my.spline.design/..." ... />
        )}
      </div>
      {/* Hero content renders instantly */}
    </section>
  );
}
```

