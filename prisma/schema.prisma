  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([deletedAt]) // M9
}

model StitchingOrder {
  id            String          @id @default(cuid())
  orderNumber   String          @unique
  customerName  String
  customerPhone String
  customerCity  String?
  suitType      String
  fabricDesc    String?
  orderDate     DateTime        @default(now())
  dueDate       DateTime
  chest         String?
  waist         String?
  hip           String?
  shoulder      String?
  shirtLength   String?
  sleeveLength  String?
  shalwarLength String?
  width         String?
  totalPrice    Decimal
  advancePaid   Decimal         @default(0)
  tailorName    String?
  status        StitchingStatus @default(PENDING)
  specialNotes  String?
  createdBy     String?
  deletedAt     DateTime? // M9
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@index([deletedAt]) // M9
}

model ManualPaymentSubmission {
  id              String              @id @default(cuid())
  orderId         String              @unique
  paymentMethod   String
  transactionId   String
  senderName      String
  screenshotUrl   String?
  status          ManualPaymentStatus @default(PENDING)
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectionReason String?
  flagged         Boolean             @default(false)
  flagReason      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  expiresAt       DateTime?
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([status])
  @@index([flagged])
}

model PageView {
  id          String   @id @default(cuid())
  url         String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

enum Role {
  CUSTOMER
  SUPER_ADMIN
  ADMIN
  MANAGER
  SUPPORT
}

enum Permission {
  VIEW_ORDERS
  MANAGE_ORDERS
  VIEW_PRODUCTS
  MANAGE_PRODUCTS
  VIEW_CUSTOMERS
  MANAGE_CUSTOMERS
  VIEW_ANALYTICS
  MANAGE_DISCOUNTS
  MANAGE_RETURNS
  MANAGE_SETTINGS
  MANAGE_SHIPPING
  MANAGE_NEWSLETTER
  VIEW_AUDIT_LOGS
  MANAGE_USERS
}

enum Badge {
  NEW
  TRENDING
  HOT
  LIMITED
  FEATURED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  JAZZCASH
  EASYPAISA
  CARD
  SAFEPAY
  NAYAPAY
  MEEZAN_BANK
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PENDING_VERIFICATION
}

enum PaymentProvider {
  JAZZCASH
  EASYPAISA
  CARD
  SAFEPAY
  NAYAPAY
  MEEZAN_BANK
}

enum TransactionStatus {
  PENDING
  INITIATED
  SUCCESS
  FAILED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationTemplate {
  ORDER_CONFIRMATION
  PAYMENT_SUCCESS
  ORDER_SHIPPED
  ORDER_DELIVERED
  ORDER_CANCELLED
  RETURN_REQUEST_SUBMITTED
  RETURN_REQUEST_APPROVED
  RETURN_REQUEST_REJECTED
  RETURN_REQUEST_COMPLETED
}

enum ReturnRequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum ReturnRequestType {
  REFUND
  EXCHANGE
}

enum ReturnReason {
  SIZE
  QUALITY
  WRONG_ITEM
  DAMAGED
  OTHER
}

enum AuditAction {
  USER_LOGIN
  USER_LOGIN_FAILED
  USER_REGISTER
  USER_LOGOUT
  ORDER_STATUS_CHANGED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  RETURN_APPROVED
  RETURN_REJECTED
  RETURN_COMPLETED
  DISCOUNT_CREATED
  DISCOUNT_UPDATED
  DISCOUNT_DELETED
  SETTINGS_CHANGED
  ADMIN_ACCESS
  MEASUREMENT_CREATED
  MEASUREMENT_UPDATED
  MEASUREMENT_DELETED
  STITCHING_ORDER_CREATED
  STITCHING_ORDER_UPDATED
  STITCHING_ORDER_DELETED
  PAYMENT_VERIFIED
  PAYMENT_REJECTED
  ORDER_DELETED
  PAYMENT_DELETED
}

enum StitchingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELIVERED
}

enum ManualPaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}
