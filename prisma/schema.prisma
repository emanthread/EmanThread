generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String?
  phone               String?
  whatsappConsent     Boolean              @default(false)
  whatsappPhone       String?
  role                Role                 @default(CUSTOMER)
  permissions         Json                 @default("[]")
  isVerified          Boolean              @default(false)
  tokenVersion        Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  addresses           Address[]
  measurement         Measurement?
  measurementProfiles MeasurementProfile[]
  orders              Order[]
  reviews             ProductReview[]
  returnRequests      ReturnRequest[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@index([createdAt])
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  label      String
  fullName   String
  phone      String
  address    String
  city       String
  province   String
  postalCode String
  isDefault  Boolean @default(false)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  image       String?
  products    Product[]
}

model FabricType {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
}

model Product {
  id                String      @id @default(cuid())
  sku               String      @unique
  name              String
  slug              String?     @unique
  description       String
  longDescription   String?
  price             Decimal
  originalPrice     Decimal?
  fabricType        String
  color             String
  colorHex          String
  images            String
  videoUrl          String?
  tags              String      @default("[]")
  badge             Badge?
  inStock           Boolean     @default(true)
  stockQuantity     Int         @default(0)
  lowStockThreshold Int         @default(5)
  metaTitle         String?
  metaDescription   String?
  categoryId        String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  imageLabels       String      @default("[]")
  orderItems        OrderItem[]
  reviews           ProductReview[]
  category          Category    @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int
  title      String?
  comment    String
  isVisible  Boolean  @default(true)
  isVerified Boolean  @default(false)
  deletedAt  DateTime? // M9
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([isVisible])
  @@index([deletedAt]) // M9
}

model Order {
  id               String                   @id @default(cuid())
  orderNumber      String                   @unique
  userId           String?
  status           OrderStatus              @default(PENDING)
  paymentMethod    PaymentMethod
  paymentStatus    PaymentStatus            @default(PENDING)
  subtotal         Decimal
  shippingCost     Decimal
  discountAmount   Decimal?
  couponCode       String?
  grandTotal       Decimal
  notes            String?
  shippingAddress  Json
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  manualPayment    ManualPaymentSubmission?
  notificationLogs NotificationLog[]
  user             User?                    @relation(fields: [userId], references: [id])
  items            OrderItem[]
  itemMeasurements OrderItemMeasurement[]
  transactions     PaymentTransaction[]
  returnRequests   ReturnRequest[]

  @@index([createdAt])
  @@index([paymentStatus])
}

model PaymentTransaction {
  id              String            @id @default(cuid())
  orderId         String
  provider        PaymentProvider
  amount          Decimal
  currency        String            @default("PKR")
  transactionRef  String?           @unique
  status          TransactionStatus @default(PENDING)
  gatewayResponse Json?
  failureReason   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([transactionRef])
}

model OrderItem {
  id                    String  @id @default(cuid())
  orderId               String
  productId             String
  quantity              Int
  priceAtTimeOfPurchase Decimal
  order                 Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               Product @relation(fields: [productId], references: [id])

  @@index([orderId, productId])
}

model NotificationLog {
  id           String   @id @default(cuid())
  orderId      String
  channel      String
  template     String
  recipient    String
  subject      String?
  content      String?
  status       String   @default("pending")
  providerRef  String?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model Discount {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String
  value       Int
  buyQuantity Int?
  getQuantity Int?
  productIds  String    @default("[]")
  minPurchase Int?
  maxDiscount Int?
  usageLimit  Int?
  usageCount  Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
}

model StoreConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ShippingZone {
  id            String   @id @default(cuid())
  name          String
  cities        String
  provinces     String
  shippingRate  Decimal
  estimatedDays String
  isActive      Boolean  @default(true)
  deletedAt     DateTime? // M9
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([deletedAt]) // M9
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  permissions String    @default("[]")
  createdBy   String
  lastUsedAt  DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([keyHash])
  @@index([active])
  @@index([createdAt])
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  userEmail String?
  action    AuditAction
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model ReturnRequest {
  id           String              @id @default(cuid())
  orderId      String
  userId       String?
  status       ReturnRequestStatus @default(PENDING)
  type         ReturnRequestType   @default(REFUND)
  reason       ReturnReason
  notes        String?
  refundAmount Decimal?
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  order        Order               @relation(fields: [orderId], references: [id])
  user         User?               @relation(fields: [userId], references: [id])
  items        ReturnRequestItem[]

  @@index([orderId])
  @@index([status])
  @@index([userId])
  @@index([createdAt])
}

model ReturnRequestItem {
  id              String        @id @default(cuid())
  returnRequestId String
  orderItemId     String
  quantity        Int
  reason          ReturnReason?
  condition       String?
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  isSubscribed   Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  source         String?

  @@index([isSubscribed])
  @@index([subscribedAt])
}

model MeasurementProfile {
  id           String                 @id @default(cuid())
  userId       String
  profileName  String
  garmentType  String
  measurements Json
  stylingPrefs Json?
  notes        String?
  deletedAt    DateTime? // M9
  isDefault    Boolean                @default(false)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems   OrderItemMeasurement[]

  @@index([userId])
  @@index([garmentType])
  @@index([isDefault])
  @@index([deletedAt]) // M9
}

model OrderItemMeasurement {
  id                   String              @id @default(cuid())
  orderId              String
  productId            String
  productName          String
  measurementProfileId String?
  measurementSnapshot  Json
  createdAt            DateTime            @default(now())
  measurementProfile   MeasurementProfile? @relation(fields: [measurementProfileId], references: [id])
  order                Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([measurementProfileId])
}

