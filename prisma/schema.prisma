  gherra1                 String    @default("")
  gherra2                 String    @default("")
  neck1                   String    @default("")
  neck2                   String    @default("")
  sleeves1                String    @default("")
  sleeves2                String    @default("")
  golai1                  String    @default("")
  golai2                  String    @default("")
  armcuff1                String    @default("")
  armcuff2                String    @default("")
  armplate1               String    @default("")
  armplate2               String    @default("")
  golbazoo1               String    @default("")
  golbazoo2               String    @default("")
  armpatti1               String    @default("")
  armpatti2               String    @default("")
  collarnok1              String    @default("")
  collarnok2              String    @default("")
  bane1                   String    @default("")
  bane2                   String    @default("")
  doubleCb                String    @default("0")
  singleCb                String    @default("0")
  golCb                   String    @default("0")
  chorasCb                String    @default("0")
  baneCb                  String    @default("0")
  collarCb                String    @default("0")
  roundneck               String    @default("0")
  shalwar1                String    @default("")
  shalwar2                String    @default("")
  shalwarGherra1          String    @default("")
  shalwarGherra2          String    @default("")
  shalwarAssan1           String    @default("")
  shalwarAssan2           String    @default("")
  shalwarPancha1          String    @default("")
  shalwarPancha2          String    @default("")
  frontPocket             String    @default("")
  sidePocket              String    @default("")
  shalwarPocket           String    @default("")
  trouserdata1            String    @default("")
  trouserdata2            String    @default("")
  trouserdata3            String    @default("")
  trouserdata4            String    @default("")
  trouserdata5            String    @default("")
  trouserdata6            String    @default("")
  trouserdata7            String    @default("")
  trouserdata8            String    @default("")
  trouserdata9            String    @default("")
  trouserdata10           String    @default("")
  trouserdata11           String    @default("")
  trouserdata12           String    @default("")
  trouserdata13           String    @default("")
  trouserdata14           String    @default("0")
  ladGolai1               String    @default("")
  ladGolai2               String    @default("")
  ladMori1                String    @default("")
  ladMori2                String    @default("")
  ladBellbazoo1           String    @default("")
  ladBellbazoo2           String    @default("")
  ladChaak1               String    @default("")
  ladChaak2               String    @default("")
  ladHip1                 String    @default("")
  ladHip2                 String    @default("")
