{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/confirm-order/layout,_N_T_/confirm-order/page,_N_T_/confirm-order,store-config"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/confirm-order/__PAGE__",
    "/confirm-order",
    "/_index",
    "/_head"
  ]
}