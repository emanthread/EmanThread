{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/payment-confirmation/layout,_N_T_/payment-confirmation/page,_N_T_/payment-confirmation,store-config"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/payment-confirmation/__PAGE__",
    "/payment-confirmation",
    "/_index",
    "/_head"
  ]
}