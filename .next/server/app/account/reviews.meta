{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/account/layout,_N_T_/account/reviews/layout,_N_T_/account/reviews/page,_N_T_/account/reviews,store-config"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/account/reviews/__PAGE__",
    "/account/reviews",
    "/account",
    "/_index",
    "/_head"
  ]
}