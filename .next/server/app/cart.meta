{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/cart/layout,_N_T_/cart/page,_N_T_/cart,store-config"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/cart/__PAGE__",
    "/cart",
    "/_index",
    "/_head"
  ]
}