{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/measurements/layout,_N_T_/measurements/page,_N_T_/measurements,store-config"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/measurements/__PAGE__",
    "/measurements",
    "/_index",
    "/_head"
  ]
}